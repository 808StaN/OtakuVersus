NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/otakuversus
JWT_SECRET=your_super_secret_jwt_key_at_least_16_chars
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ANILIST_SYNC_PAGES=8

# Storage abstraction: noop | cloudinary | supabase
STORAGE_PROVIDER=noop

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Supabase Storage (optional)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
