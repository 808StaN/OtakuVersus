generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GameSessionStatus {
  ACTIVE
  FINISHED
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  nickname     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  gameSessions GameSession[]
  guesses      Guess[]
}

model GameSession {
  id                String            @id @default(cuid())
  userId            String
  status            GameSessionStatus @default(ACTIVE)
  totalRounds       Int
  currentRoundIndex Int               @default(1)
  score             Int               @default(0)
  correctAnswers    Int               @default(0)
  startedAt         DateTime          @default(now())
  finishedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rounds Round[]
  guesses Guess[]

  @@index([userId, status])
  @@index([status, score])
}

model Round {
  id            String   @id @default(cuid())
  sessionId     String
  sceneId       String
  order         Int
  correctAnswer String
  isAnswered    Boolean  @default(false)
  createdAt     DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scene   Scene       @relation(fields: [sceneId], references: [id], onDelete: Restrict)
  guess   Guess?

  @@unique([sessionId, order])
  @@index([sceneId])
}

model Guess {
  id             String   @id @default(cuid())
  sessionId      String
  roundId        String   @unique
  userId         String
  selectedOption String
  isCorrect      Boolean
  responseTimeMs Int?
  pointsAwarded  Int
  createdAt      DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  round   Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId, createdAt])
}

model AnimeTitle {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenes Scene[]
}

model Scene {
  id           String          @id @default(cuid())
  animeTitleId String
  imageUrl     String
  difficulty   DifficultyLevel
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  animeTitle AnimeTitle @relation(fields: [animeTitleId], references: [id], onDelete: Cascade)
  rounds     Round[]

  @@index([difficulty])
}
